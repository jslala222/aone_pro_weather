# A-One Pro Weather - 배포 환경 변수 설정

# Supabase 설정 (필수)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase 서버사이드 (선택사항, 서버 함수 사용 시)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 카카오 API (필수 - 주소 검색 기능, 서버사이드만)
# https://developers.kakao.com 에서 API 키 발급
# 주의: NEXT_PUBLIC_ 제거 - 서버사이드 환경변수로 설정
KAKAO_API_KEY=your-kakao-api-key

# 배포 환경 (자동 설정, 필요시 명시)
# 개발: http://localhost:5588
# 프로덕션: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=https://aone-pro-weather.vercel.app
